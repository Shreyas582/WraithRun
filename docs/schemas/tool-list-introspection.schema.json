{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wraithrun.dev/schemas/tool-list-introspection.schema.json",
  "title": "WraithRun Tool List Introspection",
  "type": "object",
  "required": ["contract_version", "tools"],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description", "args_schema"],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "args_schema": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
