{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wraithrun.dev/schemas/automation-adapter-findings-v1.schema.json",
  "title": "WraithRun Automation Adapter Findings v1",
  "type": "object",
  "required": [
    "contract_version",
    "adapter",
    "summary",
    "findings"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "adapter": {
      "type": "string",
      "const": "findings-v1"
    },
    "summary": {
      "type": "object",
      "required": [
        "task",
        "finding_count",
        "highest_severity",
        "severity_counts"
      ],
      "properties": {
        "task": {
          "type": "string"
        },
        "case_id": {
          "type": ["string", "null"]
        },
        "finding_count": {
          "type": "integer",
          "minimum": 0
        },
        "highest_severity": {
          "type": "string",
          "enum": ["none", "info", "low", "medium", "high", "critical"]
        },
        "severity_counts": {
          "type": "object",
          "required": ["info", "low", "medium", "high", "critical"],
          "properties": {
            "info": { "type": "integer", "minimum": 0 },
            "low": { "type": "integer", "minimum": 0 },
            "medium": { "type": "integer", "minimum": 0 },
            "high": { "type": "integer", "minimum": 0 },
            "critical": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_id",
          "title",
          "severity",
          "confidence",
          "recommended_action",
          "evidence_pointer"
        ],
        "properties": {
          "finding_id": {
            "type": "string",
            "pattern": "^F-[0-9]{4}$"
          },
          "title": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": ["info", "low", "medium", "high", "critical"]
          },
          "confidence": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          },
          "recommended_action": {
            "type": "string"
          },
          "evidence_pointer": {
            "type": "object",
            "required": ["turn", "tool", "field"],
            "properties": {
              "turn": {
                "type": ["integer", "null"],
                "minimum": 1
              },
              "tool": {
                "type": ["string", "null"]
              },
              "field": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
