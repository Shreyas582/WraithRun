{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wraithrun.dev/schemas/doctor-introspection.schema.json",
  "title": "WraithRun Doctor Introspection",
  "type": "object",
  "required": ["contract_version", "summary", "checks"],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "summary": {
      "type": "object",
      "required": ["pass", "warn", "fail"],
      "properties": {
        "pass": {
          "type": "integer",
          "minimum": 0
        },
        "warn": {
          "type": "integer",
          "minimum": 0
        },
        "fail": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["status", "name", "detail"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["pass", "warn", "fail"]
          },
          "name": {
            "type": "string"
          },
          "detail": {
            "type": "string"
          },
          "reason_code": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "remediation": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "backends": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "priority", "available", "diagnostics"],
        "properties": {
          "name": {
            "type": "string"
          },
          "priority": {
            "type": "integer",
            "minimum": 0
          },
          "available": {
            "type": "boolean"
          },
          "diagnostics": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["status", "check", "detail"],
              "properties": {
                "status": {
                  "type": "string",
                  "enum": ["pass", "warn", "fail"]
                },
                "check": {
                  "type": "string"
                },
                "detail": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
